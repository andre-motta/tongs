+@patch("package_plugins.hooks.upload_after_build_wheel.time")
+@patch("package_plugins.hooks.upload_after_build_wheel.pkginfo")
+@patch("package_plugins.hooks.upload_after_build_wheel.session")
+def test_upload_retries_on_transient_5xx(
+    mock_session, mock_pkginfo, mock_time, tmp_path, caplog
+):
+    """Test that transient 5xx errors are retried with exponential backoff."""
+    mock_pkginfo.Wheel.return_value.name = "test-package"
+    mock_pkginfo.Wheel.return_value.version = "1.2.3"
+
+    error_response = Mock(status_code=502, text="Bad Gateway")
+    success_response = Mock(status_code=200)
+    success_response.raise_for_status = Mock()
+    mock_session.post.side_effect = [error_response, error_response, success_response]
+
+    wheel = tmp_path / "test_package-1.2.3-py3-none-any.whl"
+    wheel.write_bytes(b"fake wheel content")
+
+    with caplog.at_level(logging.WARNING):
+        upload_python_package_to_gitlab("test-package", "1.2.3", wheel)
+
+    assert mock_session.post.call_count == 3
+    assert mock_time.sleep.call_count == 2
+    mock_time.sleep.assert_any_call(5.0)
+    mock_time.sleep.assert_any_call(10.0)
+    assert "retrying" in caplog.text.lower()
+
+
+@patch("package_plugins.hooks.upload_after_build_wheel.time")
+@patch("package_plugins.hooks.upload_after_build_wheel.pkginfo")
+@patch("package_plugins.hooks.upload_after_build_wheel.session")
+def test_upload_raises_after_max_retries(
+    mock_session, mock_pkginfo, mock_time, tmp_path
+):
+    """Test that after exhausting retries, the 5xx error is raised."""
+    mock_pkginfo.Wheel.return_value.name = "test-package"
+    mock_pkginfo.Wheel.return_value.version = "1.2.3"
+
+    error_response = Mock(status_code=502, text="Bad Gateway")
+    error_response.raise_for_status.side_effect = req_lib.HTTPError("502 Bad Gateway")
+    mock_session.post.return_value = error_response
+
+    wheel = tmp_path / "test_package-1.2.3-py3-none-any.whl"
+    wheel.write_bytes(b"fake wheel content")
+
+    with pytest.raises(req_lib.HTTPError, match="502"):
+        upload_python_package_to_gitlab("test-package", "1.2.3", wheel)
+
+    assert mock_session.post.call_count == 4
+    assert mock_time.sleep.call_count == 3
+
